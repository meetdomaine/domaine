---
import LayoutStudio from "../../layouts/Layout-Studio.astro";
import GlobalSections from "../../components/global/sections/section-GlobalSections.astro";
import { isStaging } from "../../components/global/utils/is-staging";
import { getCollection } from "astro:content";
import { getEntry } from "astro:content";

let pageContent

// Handle SSG Routing
export async function getStaticPaths() {
  const pages = await getCollection('pagesStudio');
  return pages.map((page) => {
      return {
          params: { page: page.data.slug.current },
          props: { content: page }
      }
  })
}

// Handle SSR Routing
if (isStaging) {
  const { page } = Astro.params
  const matchedRoute = await getEntry("pagesStudio", page);
  if (matchedRoute === undefined) return Astro.redirect("/404");
  pageContent = matchedRoute.data
} else {
  const { content } = Astro.props
  pageContent = content.data
}
---
<LayoutStudio
    title={pageContent.title}
    searchFilter="type:page"
    showPreloader={pageContent.showPreloader}
>
    {pageContent.globalSections?.sections.map((section, i) => (
      <GlobalSections brand="studio" section={section} key={i} />
    ))}
</LayoutStudio>

